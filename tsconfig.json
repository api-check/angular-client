{
  "compileOnSave": false,
  "compilerOptions": {
    "paths": {
      "@api-check/angular": ["src/index.ts"]
    },
    "baseUrl": "./",
    "declaration": true,
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "module": "ES2022",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2022", "dom"]
  }
}
